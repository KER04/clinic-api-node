# ===== Servidor =====
PORT=3000

# Clave secreta para firmar/verificar los JWT (OBLIGATORIA, el server no arranca sin ella).
# Genera una con: openssl rand -hex 48
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# Orígenes permitidos para CORS, separados por coma (sin espacios).
CORS_ORIGIN=http://localhost:4200

# ===== Base de datos (MySQL) =====
DB_DIALECT=mysql
DB_ENGINE=mysql
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=clinic
DB_PORT=3306
DB_TIMEZONE=America/Bogota

# ===== Solo para pruebas =====
# Token de una sesión activa para probar rutas protegidas desde los archivos .http
TOKEN=
